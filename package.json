{
  "name": "kristorres.github.io",
  "description": "Kris Torres’s website.",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@material/elevation": "^3.1.0",
    "@material/theme": "^3.1.0",
    "@material/top-app-bar": "^3.1.0",
    "@material/typography": "^3.1.0"
  },
  "devDependencies": {
    "@axel669/rollup-plugin-path-alias": "^1.1.0",
    "@babel/core": "^7.5.5",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.4.4",
    "@babel/plugin-proposal-optional-chaining": "^7.2.0",
    "@babel/plugin-transform-react-jsx": "^7.3.0",
    "eslint": "^6.2.1",
    "eslint-plugin-react": "^7.14.3",
    "node-sass": "^4.12.0",
    "rollup": "^1.20.1",
    "rollup-plugin-babel": "^4.3.3",
    "rollup-plugin-commonjs": "^10.0.2",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-replace": "^2.2.0",
    "rollup-plugin-terser": "^5.1.1"
  },
  "scripts": {
    "build-dev": "npm run sass-dev && rollup -c ./rollup-config/dev.js",
    "build-prod": "npm run sass-prod && rollup -c ./rollup-config/prod.js",
    "sass-dev": "node-sass --include-path ./node_modules/ ./stylesheets/main.scss > ./build/dev/main.css",
    "sass-prod": "node-sass --include-path ./node_modules/ ./stylesheets/main.scss > ./build/prod/main.min.css --output-style compressed",
    "lint": "eslint ./src/"
  },
  "author": {
    "name": "Kris Torres",
    "email": "kristorresdayo@gmail.com",
    "url": "https://kristorres.github.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kristorres/kristorres.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/kristorres/kristorres.github.io/issues",
    "email": "kristorresdayo@gmail.com"
  },
  "homepage": "https://kristorres.github.io"
}
